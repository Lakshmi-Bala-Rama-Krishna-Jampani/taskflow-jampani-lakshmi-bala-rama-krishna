# PostgreSQL (used by docker-compose and DATABASE_URL for the API)
POSTGRES_USER=taskflow
POSTGRES_PASSWORD=taskflow
POSTGRES_DB=taskflow
POSTGRES_PORT=5432

# API
API_PORT=8080
JWT_SECRET=change-me-to-a-long-random-string-at-least-32-chars
BCRYPT_COST=12

# Browser must reach the API; when using docker-compose defaults, host port 8080 maps to the API.
FRONTEND_ORIGIN=http://localhost:3000
VITE_API_URL=http://localhost:8080

# Frontend (host port)
WEB_PORT=3000
